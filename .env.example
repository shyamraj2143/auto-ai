# Auto-AI environment
ENVIRONMENT=development
SECRET_KEY=change-me-generate-a-long-random-value
JWT_SECRET_KEY=
FRONTEND_URL=https://autoai.site.je
BACKEND_URL=https://auto-ai-production-c510.up.railway.app
BACKEND_CORS_ORIGINS=https://autoai.site.je,https://www.autoai.site.je
BACKEND_CORS_ORIGIN_REGEX=

# Database
DB_BACKEND=sqlite
SQLITE_PATH=database/auto_ai.db
DATABASE_URL=
MYSQL_URL=
MONGODB_URL=
MONGODB_DATABASE=auto_ai

# AI providers
AI_PROVIDER=groq

# Groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=openai/gpt-oss-120b
GROQ_SEARCH_MODEL=groq/compound-mini
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_AUDIO_MODEL=whisper-large-v3-turbo
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=4096
GROQ_RESEARCH_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile,openai/gpt-oss-120b

# Web search
TAVILY_API_KEY=your-tavily-api-key
SERPER_API_KEY=your-serper-api-key
SEARCH_CACHE_TTL_SECONDS=1800
SEARCH_MAX_RESULTS=6
SEARCH_DEEP_MAX_RESULTS=10
SEARCH_COUNTRY=us,india
SEARCH_LANGUAGE=en,hindi
#hi
# OpenAI
AUTO_AI_OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Amazon Bedrock
BEDROCK_API_KEY=your-bedrock-api-key
BEDROCK_REGION=us-east-1
BEDROCK_MODEL=openai.gpt-oss-120b
BEDROCK_ENDPOINT_MODE=mantle
BEDROCK_MANTLE_BASE_URL=
BEDROCK_AUTH_MODE=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_RESEARCH_MODELS=amazon.nova-pro-v1:0,amazon.nova-lite-v1:0,anthropic.claude-3-haiku-20240307-v1:0
DEEP_RESEARCH_DEFAULT_MAX_MODELS=3
DEEP_RESEARCH_MAX_MODELS=6
DEEP_RESEARCH_MAX_INPUT_TOKENS=6000
DEEP_RESEARCH_MAX_OUTPUT_TOKENS=1200
DEEP_RESEARCH_PER_MODEL_TIMEOUT_SECONDS=45
DEEP_RESEARCH_RATE_LIMIT_PER_MINUTE=8
DEEP_RESEARCH_GROQ_TPM_BUDGET=7600
DEEP_RESEARCH_JUDGE_PROVIDER=groq
DEEP_RESEARCH_JUDGE_MODEL=

# Security and limits
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=45
RATE_LIMIT_PER_MINUTE=90
MAX_UPLOAD_MB=20

# Password reset email
PASSWORD_RESET_FROM_EMAIL=
PASSWORD_RESET_FROM_NAME=Auto-AI
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Google OAuth / Gmail Sign-In
GOOGLE_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_WEB_CLIENT_ID=
# Android builds can also read this from android/local.properties.
AUTO_AI_GOOGLE_WEB_CLIENT_ID=
AUTO_AI_GOOGLE_SERVICES_JSON_BASE64=

# Firebase Cloud Messaging app update notifications
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_SERVICE_ACCOUNT_FILE=
AUTO_AI_UPDATE_NOTIFY_SECRET=

# First admin bootstrap. Used once on backend startup; existing admins are not modified.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=Auto-AI Admin

# APK hosting
APK_STORAGE_DIR=public/downloads
APK_FILENAME=auto-ai.apk
APK_DEFAULT_VERSION=5.5.0
APK_MIN_ANDROID_VERSION=Android 7.0

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_FAILURE_URL=https://autoai.site.je/payment/failed
RAZORPAY_PRO_LINK=
RAZORPAY_PREMIUM_LINK=
RAZORPAY_ULTRA_LINK=
RAZORPAY_CHECKOUT_CONFIG_ID=config_T9ulbVgLBfz7ko
UPI_ID=
# Optional aliases accepted by backend if your host already uses one of these names.
PAYMENT_UPI_ID=
MERCHANT_UPI_ID=
# Backward compatibility only: actual UPI IDs like name@bank are accepted here; config_ IDs are treated as Razorpay checkout configuration IDs.
RAZORPAY_UPI_ID=
UPI_PAYEE_NAME=Auto-AI
VITE_RAZORPAY_KEY_ID=
VITE_RAZORPAY_CHECKOUT_CONFIG_ID=config_T9ulbVgLBfz7ko
VITE_UPI_ID=
VITE_UPI_PAYEE_NAME=Auto-AI
PROMO_CODES=

# Frontend
# Leave blank for the public production API, or set an explicit HTTPS API URL.
VITE_API_URL=
