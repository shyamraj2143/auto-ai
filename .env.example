# Auto-AI environment
ENVIRONMENT=development
SECRET_KEY=change-me-generate-a-long-random-value
BACKEND_CORS_ORIGINS=https://autoai.site.je,https://www.autoai.site.je
BACKEND_CORS_ORIGIN_REGEX=

# Database
DB_BACKEND=sqlite
SQLITE_PATH=database/auto_ai.db
DATABASE_URL=
MYSQL_URL=
MONGODB_URL=
MONGODB_DATABASE=auto_ai

# AI providers
AI_PROVIDER=groq

# Groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=openai/gpt-oss-120b
GROQ_SEARCH_MODEL=groq/compound-mini
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_AUDIO_MODEL=whisper-large-v3-turbo
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=4096
GROQ_RESEARCH_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile,openai/gpt-oss-120b

# Web search
TAVILY_API_KEY=your-tavily-api-key
SERPER_API_KEY=your-serper-api-key
SEARCH_CACHE_TTL_SECONDS=1800
SEARCH_MAX_RESULTS=6
SEARCH_DEEP_MAX_RESULTS=10
SEARCH_COUNTRY=us,india
SEARCH_LANGUAGE=en,hindi
#hi
# OpenAI
AUTO_AI_OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Amazon Bedrock
BEDROCK_API_KEY=your-bedrock-api-key
BEDROCK_REGION=us-east-1
BEDROCK_MODEL=openai.gpt-oss-120b
BEDROCK_ENDPOINT_MODE=mantle
BEDROCK_MANTLE_BASE_URL=
BEDROCK_AUTH_MODE=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_RESEARCH_MODELS=amazon.nova-pro-v1:0,amazon.nova-lite-v1:0,anthropic.claude-3-haiku-20240307-v1:0
DEEP_RESEARCH_DEFAULT_MAX_MODELS=3
DEEP_RESEARCH_MAX_MODELS=6
DEEP_RESEARCH_MAX_INPUT_TOKENS=6000
DEEP_RESEARCH_MAX_OUTPUT_TOKENS=1200
DEEP_RESEARCH_PER_MODEL_TIMEOUT_SECONDS=45
DEEP_RESEARCH_RATE_LIMIT_PER_MINUTE=8
DEEP_RESEARCH_GROQ_TPM_BUDGET=7600
DEEP_RESEARCH_JUDGE_PROVIDER=groq
DEEP_RESEARCH_JUDGE_MODEL=

# Security and limits
ACCESS_TOKEN_EXPIRE_MINUTES=1440
RATE_LIMIT_PER_MINUTE=90
MAX_UPLOAD_MB=20

# First admin bootstrap. Used once on backend startup; existing admins are not modified.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=Auto-AI Admin

# APK hosting
APK_STORAGE_DIR=public/downloads
APK_FILENAME=auto-ai.apk
APK_DEFAULT_VERSION=5.5.0
APK_MIN_ANDROID_VERSION=Android 7.0

# Frontend
# Leave blank for the public production API, or set an explicit HTTPS API URL.
VITE_API_URL=
