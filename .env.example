# Auto-AI environment
ENVIRONMENT=development
SECRET_KEY=ztf0h2EGWbWWTd1DhhyBqX565+VyIXe1sndrq+td
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://autoai.site.je,https://www.autoai.site.je

# Database
DB_BACKEND=sqlite
SQLITE_PATH=database/auto_ai.db
DATABASE_URL=
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=auto_ai

# AI providers
AI_PROVIDER=groq

# Groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=openai/gpt-oss-120b
GROQ_SEARCH_MODEL=groq/compound-mini
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_AUDIO_MODEL=whisper-large-v3-turbo
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=4096

# OpenAI
AUTO_AI_OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Amazon Bedrock
BEDROCK_API_KEY=your-bedrock-api-key
BEDROCK_REGION=us-east-1
BEDROCK_MODEL=openai.gpt-oss-120b
BEDROCK_ENDPOINT_MODE=mantle
BEDROCK_MANTLE_BASE_URL=
BEDROCK_AUTH_MODE=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Security and limits
ACCESS_TOKEN_EXPIRE_MINUTES=1440
RATE_LIMIT_PER_MINUTE=90
MAX_UPLOAD_MB=20
ADMIN_EMAILS=

# Frontend
# Leave blank for automatic localhost/public API detection, or set a public HTTPS API URL in production.
VITE_API_URL=
